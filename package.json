{
  "name": "get-shit-done",
  "version": "1.0.0",
  "description": "A no-nonsense productivity CLI tool to help you focus and get shit done",
  "main": "src/index.js",
  "bin": {
    "gsd": "./bin/gsd.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "build": "node scripts/build.js"
  },
  "keywords": [
    "productivity",
    "cli",
    "focus",
    "tasks",
    "todo"
  ],
  "author": "get-shit-done contributors",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1",
    "conf": "^12.0.0",
    "date-fns": "^3.0.6",
    "nanoid": "^5.0.4"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "@jest/globals": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ]
  },
  "type": "module"
}
